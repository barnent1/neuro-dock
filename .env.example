# Neo4j configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neurodock

# OpenAI API configuration
OPENAI_API_KEY=your_openai_api_key

# Server configuration
PORT=4000
HOST=0.0.0.0
DEBUG=false

# Agent configuration
AGENT_POLL_INTERVAL=60  # In seconds
MAX_SUBTASKS=5  # Maximum number of subtasks when splitting a task
